# Streamlit Cloud Secrets 設定例
# 実物は Streamlit Cloud 管理画面の Settings → Secrets で設定する (リポにcommitしない)
# https://docs.streamlit.io/streamlit-community-cloud/deploy-your-app/secrets-management
#
# Streamlit Cloud の Secrets は環境変数として自動的にアプリに渡される。
# 以下と同等の内容を Streamlit Cloud 画面でTOML形式で貼り付ける。

SHEETS_OAUTH_REFRESH_TOKEN = "1//0ec..."
SOCIALDATA_API_KEY = "7640|..."
APP_PASSWORD = "your_password_here"

# oauth_client.json の中身を JSON文字列で
OAUTH_CLIENT_JSON = '{"installed":{"client_id":"...","client_secret":"...","token_uri":"https://oauth2.googleapis.com/token"}}'
